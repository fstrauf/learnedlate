{
  "name": "learnedlate",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "npx vercel dev --yes --listen 3020",
    "dev:stack": "concurrently \"pnpm dev\" \"pnpm dev:api\"",
    "build": "node scripts/generate-sitemap.js && vue-tsc -b && pnpm run build:client && pnpm run build:server && pnpm run prerender && pnpm run build:api",
    "build:api": "node scripts/build-api.js",
    "prebuild": "node scripts/generate-sitemap.js",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --outDir dist/server --ssr src/entry-server.ts",
    "prerender": "node scripts/prerender.js",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "cv:pdf": "node scripts/cv-to-pdf.mjs",
    "verify-prerender": "node scripts/verify-prerender.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@unhead/vue": "^2.0.10",
    "@vercel/node": "^5.5.15",
    "@vueuse/core": "^14.2.1",
    "@vueuse/head": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lodash-es": "^4.17.21",
    "lucide-vue-next": "^0.577.0",
    "posthog-js": "^1.254.0",
    "reka-ui": "^2.9.0",
    "stripe": "^20.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.5",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.3.5",
    "@vitejs/plugin-vue": "^5.2.2",
    "@vue/tsconfig": "^0.7.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.1",
    "esbuild": "^0.27.3",
    "marked": "^15.0.11",
    "playwright": "^1.58.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.0.0",
    "terser": "^5.43.0",
    "typescript": "~5.7.2",
    "vite": "^6.3.1",
    "vue-tsc": "^2.2.8"
  }
}
